// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    BigInt               @id @default(autoincrement()) @db.BigInt
  email                 String?              @db.VarChar(255)
  nickname              String               @db.VarChar(50)
  profileImageUrl       String?              @map("profile_image_url") @db.VarChar(500)
  role                  String               @default("USER") @db.VarChar(20)
  status                String               @default("ACTIVE") @db.VarChar(20)
  currentSubscriptionId BigInt?              @map("current_subscription_id") @db.BigInt
  notification          Boolean              @default(true)
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  deletedAt             DateTime?            @map("deleted_at")
  socialAccounts        SocialAccount[]
  termAgreements        UserTermsAgreement[]
  currentSubscription   UserSubscription?    @relation("CurrentUserSubscription", fields: [currentSubscriptionId, id], references: [id, userId])
  subscriptions         UserSubscription[]   @relation("UserSubscriptions")
  billingKeys           BillingKey[]
  payments              Payment[]

  @@unique([currentSubscriptionId, id])
  @@map("users")
}

model SocialAccount {
  id             BigInt   @id @default(autoincrement()) @db.BigInt
  userId         BigInt   @map("user_id") @db.BigInt
  provider       String   @db.VarChar(30)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  providerEmail  String?  @map("provider_email") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("social_accounts")
}

model Term {
  id            BigInt               @id @default(autoincrement()) @db.BigInt
  title         String               @db.VarChar(100)
  type          String               @db.VarChar(30)
  version       String               @db.VarChar(20)
  contentUrl    String?              @map("content_url") @db.VarChar(500)
  isRequired    Boolean              @default(true) @map("is_required")
  isActive      Boolean              @default(true) @map("is_active")
  effectiveFrom DateTime             @map("effective_from")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  agreements    UserTermsAgreement[]

  @@unique([type, version])
  @@map("terms")
}

model UserTermsAgreement {
  id          BigInt    @id @default(autoincrement()) @db.BigInt
  termId      BigInt    @map("term_id") @db.BigInt
  userId      BigInt    @map("user_id") @db.BigInt
  isAgreed    Boolean   @map("is_agreed")
  agreedAt    DateTime? @map("agreed_at")
  withdrawnAt DateTime? @map("withdrawn_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  term        Term      @relation(fields: [termId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([termId])
  @@index([userId, termId, createdAt])
  @@map("users_terms_agreements")
}

model SubscriptionPlan {
  id                BigInt                    @id @default(autoincrement()) @db.BigInt
  code              String                    @unique @db.VarChar(20)
  name              String                    @db.VarChar(50)
  price             Int
  billingCycle      String                    @map("billing_cycle") @db.VarChar(20)
  description       String?                   @db.VarChar(255)
  isActive          Boolean                   @default(true) @map("is_active")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  planFeatures      SubscriptionPlanFeature[]
  userSubscriptions UserSubscription[]

  @@map("subscription_plans")
}

model PlanFeature {
  id                       BigInt                    @id @default(autoincrement()) @db.BigInt
  code                     String                    @unique @db.VarChar(50)
  name                     String                    @db.VarChar(100)
  description              String?                   @db.VarChar(255)
  valueType                String                    @map("value_type") @db.VarChar(20)
  unit                     String?                   @db.VarChar(20)
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  subscriptionPlanFeatures SubscriptionPlanFeature[]

  @@map("plan_features")
}

model SubscriptionPlanFeature {
  id                 BigInt           @id @default(autoincrement()) @db.BigInt
  subscriptionPlanId BigInt           @map("subscription_plan_id") @db.BigInt
  planFeatureId      BigInt           @map("plan_feature_id") @db.BigInt
  isEnabled          Boolean          @default(true) @map("is_enabled")
  limitValue         Int?             @map("limit_value")
  textValue          String?          @map("text_value") @db.VarChar(255)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  subscriptionPlan   SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
  planFeature        PlanFeature      @relation(fields: [planFeatureId], references: [id])

  @@unique([subscriptionPlanId, planFeatureId])
  @@index([planFeatureId])
  @@map("subscription_plan_features")
}

model UserSubscription {
  id                 BigInt           @id @default(autoincrement()) @db.BigInt
  userId             BigInt           @map("user_id") @db.BigInt
  subscriptionPlanId BigInt           @map("subscription_plan_id") @db.BigInt
  startedAt          DateTime         @map("started_at")
  expiresAt          DateTime         @map("expires_at")
  canceledAt         DateTime?        @map("canceled_at")
  autoRenew          Boolean          @default(true) @map("auto_renew")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  user               User             @relation("UserSubscriptions", fields: [userId], references: [id])
  currentForUser     User?            @relation("CurrentUserSubscription")
  subscriptionPlan   SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
  payments           Payment[]

  @@unique([id, userId])
  @@index([userId])
  @@index([subscriptionPlanId])
  @@map("users_subscriptions")
}

model BillingKey {
  id               BigInt    @id @default(autoincrement()) @db.BigInt
  userId           BigInt    @map("user_id") @db.BigInt
  paymentProvider  String    @map("payment_provider") @db.VarChar(30)
  billingKey       String    @map("billing_key") @db.VarChar(500)
  customerKey      String    @map("customer_key") @db.VarChar(255)
  cardCompany      String?   @map("card_company") @db.VarChar(50)
  cardNumberMasked String?   @map("card_number_masked") @db.VarChar(30)
  status           String    @default("ACTIVE") @db.VarChar(20)
  issuedAt         DateTime  @map("issued_at")
  deactivatedAt    DateTime? @map("deactivated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id])
  payments         Payment[]

  @@unique([id, userId])
  @@index([userId])
  @@map("billing_keys")
}

model Payment {
  id                  BigInt            @id @default(autoincrement()) @db.BigInt
  userId              BigInt            @map("user_id") @db.BigInt
  usersSubscriptionId BigInt?           @map("users_subscription_id") @db.BigInt
  billingKeyId        BigInt?           @map("billing_key_id") @db.BigInt
  orderId             String            @unique @map("order_id") @db.VarChar(100)
  orderName           String            @map("order_name") @db.VarChar(100)
  amount              Int
  paymentMethod       String?           @map("payment_method") @db.VarChar(30)
  paymentProvider     String            @map("payment_provider") @db.VarChar(30)
  providerPaymentId   String?           @map("provider_payment_id") @db.VarChar(255)
  status              String            @db.VarChar(20)
  paidAt              DateTime?         @map("paid_at")
  failedAt            DateTime?         @map("failed_at")
  canceledAt          DateTime?         @map("canceled_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  user                User              @relation(fields: [userId], references: [id])
  usersSubscription   UserSubscription? @relation(fields: [usersSubscriptionId, userId], references: [id, userId])
  billingKey          BillingKey?       @relation(fields: [billingKeyId, userId], references: [id, userId])
  receipt             PaymentReceipt?

  @@unique([paymentProvider, providerPaymentId])
  @@index([userId])
  @@index([usersSubscriptionId])
  @@index([billingKeyId])
  @@map("payments")
}

model PaymentReceipt {
  id         BigInt    @id @default(autoincrement()) @db.BigInt
  paymentId  BigInt    @unique @map("payment_id") @db.BigInt
  receiptUrl String?   @map("receipt_url") @db.VarChar(500)
  issuedAt   DateTime? @map("issued_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  payment    Payment   @relation(fields: [paymentId], references: [id])

  @@map("payment_receipts")
}
