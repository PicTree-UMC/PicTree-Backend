DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# 값은 따옴표 없이 작성합니다. docker run --env-file 은 따옴표를 값의 일부로 읽습니다.
DATABASE_URL=mysql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# 쉼표로 여러 origin을 등록합니다. Vercel 배포 주소는 https:// 포함해서 입력합니다.
CORS_ORIGINS=http://localhost:5173,https://<VERCEL_PROJECT>.vercel.app

JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=
JWT_ACCESS_TOKEN_EXPIRES_IN=3600
JWT_REFRESH_TOKEN_EXPIRES_IN=1209600

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

TOSS_PAYMENTS_SECRET_KEY=
TOSS_PAYMENTS_BASE_URL=https://api.tosspayments.com
TOSS_BILLING_CUSTOMER_KEY_SECRET=
